rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == "dalinadjib1990@gmail.com" ||
        request.auth.token.email == "admin@ais-dev.com" ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }

    function isGroupAdmin(groupId) {
      return isSignedIn() && (
        isAdmin() || 
        (exists(/databases/$(database)/documents/groups/$(groupId)) && 
         request.auth.uid in get(/databases/$(database)/documents/groups/$(groupId)).data.admins)
      );
    }

    function isGroupMember(groupId) {
      return isSignedIn() && (
        isAdmin() || 
        (exists(/databases/$(database)/documents/groups/$(groupId)) && 
         request.auth.uid in get(/databases/$(database)/documents/groups/$(groupId)).data.members)
      );
    }

    function isValidId(id) {
      return id is string && id.size() > 0 && id.size() <= 128;
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isVerified() {
      // In development/AI Studio, we allow all signed-in users to interact for better UX.
      return isSignedIn();
    }

    function isJoinAction() {
      return incoming().diff(existing()).affectedKeys().hasOnly(['members', 'memberCount', 'pendingRequests']);
    }

    // ===============================================================
    // Validation Blueprints (The "Anti-Update-Gap")
    // ===============================================================

    function isValidUserProfile(data) {
      return (request.method == 'create' ? data.keys().hasAll(['uid', 'displayName', 'photoURL', 'createdAt']) : true) &&
             data.keys().size() <= 80 &&
             (!('uid' in data) || data.uid == request.auth.uid) &&
             (!('displayName' in data) || (data.displayName is string && data.displayName.size() > 0 && data.displayName.size() <= 100)) &&
             (!('photoURL' in data) || (data.photoURL is string && data.photoURL.size() <= 2000)) &&
             (!('createdAt' in data) || (request.method == 'create' ? data.createdAt == request.time : data.createdAt == existing().createdAt)) &&
             (!('firstName' in data) || (data.firstName is string && data.firstName.size() <= 50)) &&
             (!('lastName' in data) || (data.lastName is string && data.lastName.size() <= 50)) &&
             (!('bio' in data) || (data.bio is string && data.bio.size() <= 2000)) &&
             (!('subject' in data) || (data.subject is string && data.subject.size() <= 100)) &&
             (!('school' in data) || (data.school is string && data.school.size() <= 100)) &&
             (!('wilaya' in data) || (data.wilaya is string && data.wilaya.size() <= 100)) &&
             (!('level' in data) || (data.level is string && data.level.size() <= 100)) &&
             (!('yearsOfExperience' in data) || (data.yearsOfExperience is number)) &&
             (!('gender' in data) || (data.gender is string && data.gender.size() <= 20)) &&
             (!('birthDate' in data) || (data.birthDate is string && data.birthDate.size() <= 20)) &&
             (!('role' in data) || (data.role is string && data.role.size() <= 50)) &&
             (!('rank' in data) || (data.rank is string && data.rank.size() <= 50)) &&
             (!('isProfileComplete' in data) || (data.isProfileComplete is bool)) &&
             (!('showEmail' in data) || (data.showEmail is bool)) &&
             (!('showPhone' in data) || (data.showPhone is bool)) &&
             (!('lastSeen' in data) || (data.lastSeen == request.time || (request.method == 'update' && data.lastSeen == existing().lastSeen))) &&
             (!('followers' in data) || (data.followers is list && data.followers.size() <= 10000)) &&
             (!('following' in data) || (data.following is list && data.following.size() <= 10000)) &&
             (!('friends' in data) || (data.friends is list && data.friends.size() <= 5000)) &&
             (!('blockedUsers' in data) || (data.blockedUsers is list && data.blockedUsers.size() <= 1000)) &&
             (!('bioBackground' in data) || (data.bioBackground is string && data.bioBackground.size() <= 500)) &&
             (!('bioTextColor' in data) || (data.bioTextColor is string && data.bioTextColor.size() <= 50)) &&
             (!('isActivated' in data) || (data.isActivated is bool)) &&
             (!('premiumUntil' in data) || (data.premiumUntil is timestamp)) &&
             (!('lastGenerationDate' in data) || (data.lastGenerationDate is timestamp)) &&
             (!('lastUsageResetDate' in data) || (data.lastUsageResetDate is timestamp)) &&
             (!('dailyGenCount' in data) || (data.dailyGenCount is int)) &&
             (!('dailyCorrectCount' in data) || (data.dailyCorrectCount is int)) &&
             (!('savedPreferences' in data) || (data.savedPreferences is map)) &&
             (!('appBackground' in data) || (data.appBackground is string && data.appBackground.size() <= 2000)) &&
             (!('phoneNumber' in data) || (data.phoneNumber is string && data.phoneNumber.size() <= 20)) &&
             (!('email' in data) || (data.email is string && data.email.size() <= 100)) &&
             (!('usage' in data) || (data.usage is map)) &&
             (!('reminders' in data) || (data.reminders is map)) &&
             (!('peerId' in data) || (data.peerId is string && data.peerId.size() <= 200)) &&
             (!('settings' in data) || (data.settings is map));
    }

    function isValidUserPrivateData(data) {
      return (!('email' in data) || (data.email is string && data.email.size() <= 100)) &&
             (!('phoneNumber' in data) || (data.phoneNumber is string && data.phoneNumber.size() <= 20)) &&
             (!('settings' in data) || (data.settings is map)) &&
             (!('reminders' in data) || (data.reminders is map));
    }

    function isValidPost(data) {
      return (request.method == 'create' ? data.keys().hasAll(['authorId', 'authorName', 'authorPhoto', 'content', 'likes', 'commentCount', 'createdAt']) : true) &&
             (!('authorId' in data) || data.authorId == request.auth.uid) &&
             (!('authorName' in data) || (data.authorName is string && data.authorName.size() > 0)) &&
             (!('authorPhoto' in data) || (data.authorPhoto is string)) &&
             (!('content' in data) || (data.content is string && data.content.size() > 0 && data.content.size() <= 5000)) &&
             (!('likes' in data) || (data.likes is list && data.likes.size() <= 10000)) &&
             (!('commentCount' in data) || (data.commentCount is int && data.commentCount >= 0)) &&
             (!('privacy' in data) || data.privacy in ['public', 'friends', 'private']) &&
             (!('imageUrl' in data) || data.imageUrl == null || (data.imageUrl is string && data.imageUrl.size() <= 1000)) &&
             (!('videoUrl' in data) || data.videoUrl == null || (data.videoUrl is string && data.videoUrl.size() <= 1000)) &&
             (!('background' in data) || (data.background == null || (data.background is string && data.background.size() <= 100))) &&
             (!('reactions' in data) || data.reactions is map) &&
             (!('republishedFrom' in data) || (data.republishedFrom is string)) &&
             (!('republishedAuthor' in data) || (data.republishedAuthor is string)) &&
             (!('createdAt' in data) || (request.method == 'create' ? data.createdAt == request.time : data.createdAt == existing().createdAt));
    }

    function isValidComment(data) {
      return (request.method == 'create' ? data.keys().hasAll(['postId', 'authorId', 'authorName', 'authorPhoto', 'content', 'createdAt']) : true) &&
             (!('authorId' in data) || data.authorId == request.auth.uid) &&
             (!('postId' in data) || data.postId is string) &&
             (!('content' in data) || (data.content is string && (data.content.size() > 0 || ('imageUrl' in data)) && data.content.size() <= 2000)) &&
             (!('parentId' in data) || (data.parentId is string)) &&
             (!('replyTo' in data) || (data.replyTo is string)) &&
             (!('imageUrl' in data) || (data.imageUrl is string && data.imageUrl.size() <= 1000)) &&
             (!('createdAt' in data) || (request.method == 'create' ? data.createdAt == request.time : data.createdAt == existing().createdAt));
    }

    function isValidProduct(data) {
      return (request.method == 'create' ? data.keys().hasAll(['sellerId', 'sellerName', 'sellerPhoto', 'title', 'description', 'price', 'category', 'wilaya', 'images', 'status', 'hasDelivery', 'createdAt']) : true) &&
             (!('sellerId' in data) || data.sellerId == request.auth.uid) &&
             (!('sellerName' in data) || data.sellerName is string) &&
             (!('sellerPhoto' in data) || data.sellerPhoto is string) &&
             (!('title' in data) || (data.title is string && data.title.size() > 0 && data.title.size() <= 200)) &&
             (!('description' in data) || (data.description is string && data.description.size() <= 2000)) &&
             (!('price' in data) || (data.price is number && data.price >= 0)) &&
             (!('category' in data) || data.category is string) &&
             (!('wilaya' in data) || data.wilaya is string) &&
             (!('images' in data) || (data.images is list && data.images.size() > 0 && data.images.size() <= 5)) &&
             (!('status' in data) || data.status in ['available', 'sold']) &&
             (!('hasDelivery' in data) || data.hasDelivery is bool) &&
             (!('sellerPhone' in data) || data.sellerPhone is string) &&
             (!('createdAt' in data) || (request.method == 'create' ? data.createdAt == request.time : data.createdAt == existing().createdAt));
    }
    function isValidNotification(data) {
      return (request.method == 'create' ? data.keys().hasAll(['recipientId', 'senderId', 'senderName', 'type', 'read', 'createdAt']) : true) &&
             (!('senderId' in data) || (data.senderId == request.auth.uid || isAdmin() || (data.recipientId == request.auth.uid && (data.type == 'missed_call' || data.type == 'group_request')))) &&
             (!('recipientId' in data) || data.recipientId is string) &&
             (!('senderName' in data) || data.senderName is string) &&
             (!('type' in data) || data.type in ['like', 'comment', 'follow', 'missed_call', 'market_interest', 'group_invite', 'group_request', 'group_accepted', 'group_rejected']) &&
             (!('read' in data) || data.read is bool) &&
             (!('message' in data) || data.message is string) &&
             (!('postId' in data) || data.postId is string) &&
             (!('groupId' in data) || data.groupId is string) &&
             (!('createdAt' in data) || (request.method == 'create' ? data.createdAt == request.time : data.createdAt == existing().createdAt));
    }

    function isValidMessage(data) {
      return (request.method == 'create' ? data.keys().hasAll(['roomId', 'participants', 'senderId', 'senderName', 'seen', 'createdAt']) : true) &&
             (!('senderId' in data) || data.senderId == request.auth.uid) &&
             (!('roomId' in data) || data.roomId is string) &&
             (!('participants' in data) || (data.participants is list && (data.roomId == 'global' ? 'global' in data.participants : request.auth.uid in data.participants))) &&
             (!('senderName' in data) || data.senderName is string) &&
             (!('seen' in data) || data.seen is bool) &&
             (!('text' in data) || (data.text is string && data.text.size() <= 2000)) &&
             (!('imageUrl' in data) || (data.imageUrl is string && data.imageUrl.size() <= 1000)) &&
             (!('audioUrl' in data) || (data.audioUrl is string && data.audioUrl.size() <= 1000)) &&
             (!('videoUrl' in data) || (data.videoUrl is string && data.videoUrl.size() <= 1000)) &&
             (!('reactions' in data) || (data.reactions is map)) &&
             (!('clientCreatedAt' in data) || (data.clientCreatedAt is int)) &&
             (!('createdAt' in data) || (request.method == 'create' ? data.createdAt == request.time : data.createdAt == existing().createdAt));
    }

    function isValidEducationalGroup(data) {
      return (request.method == 'create' ? data.keys().hasAll(['name', 'creatorId', 'admins', 'members', 'privacy', 'createdAt']) : true) &&
             (!('creatorId' in data) || data.creatorId == request.auth.uid) &&
             (!('name' in data) || (data.name is string && data.name.size() > 0 && data.name.size() <= 100)) &&
             (!('admins' in data) || (data.admins is list && request.auth.uid in data.admins)) &&
             (!('members' in data) || (data.members is list && request.auth.uid in data.members)) &&
             (!('privacy' in data) || data.privacy in ['public', 'private', 'hidden']) &&
             (!('description' in data) || (data.description is string && data.description.size() <= 2000)) &&
             (!('coverImage' in data) || (data.coverImage is string && data.coverImage.size() <= 2000)) &&
             (!('autoJoin' in data) || (data.autoJoin is bool)) &&
             (!('requireTeacherVerification' in data) || (data.requireTeacherVerification is bool)) &&
             (!('memberCount' in data) || (data.memberCount is int)) &&
             (!('pendingRequests' in data) || (data.pendingRequests is list)) &&
             (!('tags' in data) || (data.tags is list)) &&
             (!('rules' in data) || (data.rules is list)) &&
             (!('createdAt' in data) || (request.method == 'create' ? data.createdAt == request.time : data.createdAt == existing().createdAt));
    }

    function isValidGroupPost(data) {
      return isValidPost(data) && (!('groupId' in data) || (data.groupId is string));
    }

    function isValidDiscussion(data) {
      return (request.method == 'create' ? data.keys().hasAll(['title', 'category', 'authorId', 'authorName', 'authorPhoto', 'createdAt', 'lastActivity', 'repliesCount', 'viewsCount']) : true) &&
             (!('authorId' in data) || data.authorId == request.auth.uid) &&
             (!('title' in data) || (data.title is string && data.title.size() > 0 && data.title.size() <= 300)) &&
             (!('category' in data) || data.category is string) &&
             (!('authorName' in data) || data.authorName is string) &&
             (!('authorPhoto' in data) || data.authorPhoto is string) &&
             (!('repliesCount' in data) || data.repliesCount is int) &&
             (!('viewsCount' in data) || data.viewsCount is int) &&
             (!('createdAt' in data) || (request.method == 'create' ? data.createdAt == request.time : data.createdAt == existing().createdAt));
    }

    function isValidDiscussionMessage(data) {
      return (request.method == 'create' ? data.keys().hasAll(['text', 'senderId', 'senderName', 'senderPhoto', 'createdAt']) : true) &&
             (!('senderId' in data) || data.senderId == request.auth.uid) &&
             (!('text' in data) || (data.text is string && data.text.size() > 0 && data.text.size() <= 5000)) &&
             (!('senderName' in data) || data.senderName is string) &&
             (!('senderPhoto' in data) || data.senderPhoto is string) &&
             (!('createdAt' in data) || (request.method == 'create' ? data.createdAt == request.time : data.createdAt == existing().createdAt));
    }

    function isValidCall(data) {
      return (request.method == 'create' ? data.keys().hasAll(['senderId', 'recipientId', 'type', 'status', 'createdAt']) : true) &&
             (!('senderId' in data) || data.senderId is string) &&
             (!('recipientId' in data) || data.recipientId is string) &&
             (!('type' in data) || data.type in ['audio', 'video']) &&
             (!('status' in data) || data.status in ['ringing', 'connected', 'accepted', 'rejected', 'missed', 'ended', 'failed']) &&
             (!('senderName' in data) || data.senderName is string || data.senderName == null) &&
             (!('senderPhoto' in data) || data.senderPhoto is string || data.senderPhoto == null) &&
             (!('senderPeerId' in data) || data.senderPeerId is string || data.senderPeerId == null) &&
             (!('recipientPeerId' in data) || data.recipientPeerId is string || data.recipientPeerId == null) &&
             (!('error' in data) || data.error is string) &&
             (!('endedAt' in data) || data.endedAt is timestamp || data.endedAt == null) &&
             (!('createdAt' in data) || (request.method == 'create' ? data.createdAt == request.time : true));
    }

    // ===============================================================
    // Collection Rules
    // ===============================================================

    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isOwner(userId) && isValidUserProfile(incoming());
      allow update: if (isOwner(userId) && (
          incoming().uid == existing().uid &&
          (incoming().createdAt == existing().createdAt || !('createdAt' in incoming()))
        )) || (
          // Social interaction: anyone can add themselves to followers/following/friends
          isSignedIn() && incoming().diff(existing()).affectedKeys().hasOnly(['followers', 'following', 'friends', 'blockedUsers']) &&
          incoming().uid == existing().uid
        ) || isAdmin();
      allow delete: if isAdmin();
    }

    match /users_private/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && isValidUserPrivateData(incoming());
      allow update: if (isOwner(userId) && isValidUserPrivateData(incoming())) || isAdmin();
    }

    match /posts/{postId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn() && (resource.data.privacy == 'public' || resource.data.authorId == request.auth.uid);
      allow create: if isSignedIn() && isValidPost(incoming());
      allow update: if (isOwner(existing().authorId) && isValidPost(incoming()) && (
          incoming().diff(existing()).affectedKeys().hasOnly(['content', 'privacy', 'imageUrl', 'videoUrl', 'background', 'reactions']) &&
          incoming().authorId == existing().authorId &&
          incoming().createdAt == existing().createdAt
        )) || (
          // Social interaction: anyone can like or increment comment count
          isSignedIn() && incoming().diff(existing()).affectedKeys().hasOnly(['likes', 'commentCount', 'reactions'])
        ) || isAdmin();
      allow delete: if (isOwner(existing().authorId) || isAdmin());
    }

    match /comments/{commentId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isSignedIn() && isValidComment(incoming()) && exists(/databases/$(database)/documents/posts/$(incoming().postId));
      allow update: if (isOwner(existing().authorId) && isValidComment(incoming()) && (
          incoming().diff(existing()).affectedKeys().hasOnly(['content']) &&
          incoming().authorId == existing().authorId &&
          incoming().postId == existing().postId
        )) || isAdmin();
      allow delete: if (isOwner(existing().authorId) || (isSignedIn() && exists(/databases/$(database)/documents/posts/$(existing().postId)) && get(/databases/$(database)/documents/posts/$(existing().postId)).data.authorId == request.auth.uid) || isAdmin());
    }

    match /notifications/{notificationId} {
      allow get: if isOwner(resource.data.recipientId) || isAdmin();
      allow list: if isSignedIn() && resource.data.recipientId == request.auth.uid;
      allow create: if isSignedIn() && isValidNotification(incoming());
      allow update: if (isOwner(existing().recipientId) && incoming().diff(existing()).affectedKeys().hasOnly(['read'])) || isAdmin();
      allow delete: if isOwner(existing().recipientId) || isAdmin();
    }

    match /messages/{messageId} {
      allow get: if isSignedIn() && (resource == null || resource.data.roomId == 'global' || request.auth.uid in resource.data.participants);
      allow list: if isSignedIn() && (resource.data.roomId == 'global' || request.auth.uid in resource.data.participants);
      allow create: if isSignedIn() && isValidMessage(incoming());
      allow update: if ((isSignedIn() && (existing().roomId == 'global' || request.auth.uid in existing().participants) && (
          incoming().diff(existing()).affectedKeys().hasOnly(['seen', 'reactions', 'deletedFor', 'clientCreatedAt'])
        )) || isAdmin());
      allow delete: if isOwner(existing().senderId) || isAdmin();
    }

    match /invitations/{invitationId} {
      allow get: if isSignedIn() && (resource == null || request.auth.uid in resource.data.participants || isAdmin());
      allow list: if isSignedIn() && (request.auth.uid in resource.data.participants || isAdmin());
      allow create: if isSignedIn() && (incoming().senderId == request.auth.uid || isAdmin());
      allow update: if isSignedIn() && (request.auth.uid in existing().participants || isAdmin());
      allow delete: if isSignedIn() && (request.auth.uid in existing().participants || isAdmin());
    }

    match /friendRequests/{requestId} {
      allow get: if isSignedIn() && (request.auth.uid == resource.data.senderId || request.auth.uid == resource.data.receiverId);
      allow list: if isSignedIn() && (request.auth.uid == resource.data.senderId || request.auth.uid == resource.data.receiverId);
      allow create: if isSignedIn() && incoming().senderId == request.auth.uid;
      allow update: if isSignedIn() && (request.auth.uid == existing().senderId || request.auth.uid == existing().receiverId);
      allow delete: if isSignedIn() && (request.auth.uid == existing().senderId || request.auth.uid == existing().receiverId);
    }

    match /products/{productId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn() && isValidProduct(incoming());
      allow update: if ((isOwner(existing().sellerId) && isValidProduct(incoming()) && (
          incoming().diff(existing()).affectedKeys().hasOnly(['title', 'description', 'price', 'category', 'wilaya', 'images', 'status', 'hasDelivery']) &&
          incoming().sellerId == existing().sellerId
        )) || isAdmin());
      allow delete: if isOwner(existing().sellerId) || isAdmin();
    }

    match /calls/{callId} {
      allow get, list: if isSignedIn() && (resource == null || request.auth.uid == resource.data.senderId || request.auth.uid == resource.data.recipientId || isAdmin());
      allow create: if isSignedIn() && isValidCall(incoming()) && 
                    incoming().senderId == request.auth.uid;
      allow update: if isSignedIn() && (
          // Participants or Admin can update
          (request.auth.uid == existing().senderId || request.auth.uid == existing().recipientId || isAdmin())
        );
      allow delete: if isSignedIn() && (request.auth.uid == existing().senderId || request.auth.uid == existing().recipientId || isAdmin());
    }

    match /groups/{groupId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isSignedIn() && isValidEducationalGroup(incoming());
      allow update: if isSignedIn() && (
        (incoming().creatorId == request.auth.uid && isValidEducationalGroup(incoming())) ||
        (isSignedIn() && incoming().diff(existing()).affectedKeys().hasOnly(['members', 'admins', 'pendingRequests', 'memberCount'])) ||
        isAdmin()
      );
      allow delete: if (isSignedIn() && existing().creatorId == request.auth.uid) || isAdmin();
    }

    match /group_posts/{postId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isSignedIn() && isValidGroupPost(incoming());
      allow update: if isSignedIn() && (
        (existing().authorId == request.auth.uid && isValidGroupPost(incoming())) ||
        (isSignedIn() && incoming().diff(existing()).affectedKeys().hasOnly(['likes', 'commentCount', 'reactions'])) ||
        isGroupAdmin(existing().groupId)
      );
      allow delete: if (isSignedIn() && existing().authorId == request.auth.uid) || isGroupAdmin(existing().groupId);
    }

    match /group_comments/{commentId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isSignedIn() && isValidComment(incoming());
      allow update: if isSignedIn() && (
        (existing().authorId == request.auth.uid && isValidComment(incoming())) ||
        isAdmin()
      );
      allow delete: if (isSignedIn() && existing().authorId == request.auth.uid) || isAdmin();
    }

    match /discussions/{topicId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn() && isValidDiscussion(incoming());
      allow update: if (
        (existing().authorId == request.auth.uid && isValidDiscussion(incoming())) ||
        (isSignedIn() && incoming().diff(existing()).affectedKeys().hasOnly(['viewsCount', 'repliesCount', 'lastActivity'])) ||
        isAdmin()
      );
      allow delete: if (isSignedIn() && existing().authorId == request.auth.uid) || isAdmin();

      match /messages/{messageId} {
        allow get, list: if isSignedIn();
        allow create: if isSignedIn() && isValidDiscussionMessage(incoming());
        allow update, delete: if (isSignedIn() && existing().senderId == request.auth.uid) || isAdmin();
      }
    }

    match /typing/{roomId} {
      allow read, write: if isSignedIn() && (roomId == 'global' || roomId.matches('.*' + request.auth.uid + '.*'));
    }

    match /activation_codes/{codeId} {
      // Admin has full control
      allow read, write: if isAdmin();
      
      // Regular users can query to find a code and use it
      allow list, get, delete: if isSignedIn();
    }

    match /admins/{adminId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // Connection test path
    match /_connection_test_/{docId} {
      allow read: if true;
      allow write: if isSignedIn();
    }
  }
}
