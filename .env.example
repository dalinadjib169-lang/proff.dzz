# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# VITE_AGORA_APP_ID: Required for Agora video/audio calls.
VITE_AGORA_APP_ID=8caf4f84ad15420792f81cf1dbf9944f
# VITE_AGORA_TOKEN: Optional. If your project has App Certificate enabled, you must provide a token.
VITE_AGORA_TOKEN=
